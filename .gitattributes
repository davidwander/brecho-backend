# Auto detect text files and perform LF normalization
* text=auto

# Prisma files
*.prisma text eol=lf
*.sql text eol=lf

# TypeScript and JavaScript files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.config.js text eol=lf
.env* text eol=lf
.git* text eol=lf 